// Creator Engine — Prisma Schema
// Stack: PostgreSQL + Next.js + NextAuth v5
// Contexto de negocio isolado no schema Postgres "creator_engine"
// (definido via ?schema=creator_engine na DATABASE_URL).
// Database: personal_db. Schemas vizinhos: public (pessoal) e rag (vetorial).

generator client {
  provider      = "prisma-client-js"
  // native = engine local (dev); debian-openssl-3.0.x = container node:22-slim em prod
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PLANO DE ATAQUE ─────────────────────────────────────────────────────────
// Reconstruido na app (DEPLOY.md). Legado public.creator_engine_state permanece
// para hermes-agent; esta tabela e a fonte de verdade da UI.

model PlanoAtaqueItem {
  id        String   @id @default(cuid())
  fase      String
  titulo    String
  descricao String?  @db.Text
  concluido Boolean  @default(false)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fase, ordem])
  @@map("plano_ataque_item")
}

// ─── AUTH ───────────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String?
  totpSecret  String?   @db.Text
  totpEnabled Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sessions    Session[]
  accounts    Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── PERSONAS ────────────────────────────────────────────────────────────────

model Persona {
  id                   String        @id @default(cuid())
  slug                 String        @unique
  nomeArtistico        String
  status               PersonaStatus @default(TESTE)
  nicho                String
  aparencia            String?       @db.Text
  personalidade        String?       @db.Text
  backstory            String?       @db.Text
  incongruenciaCentral String?       @db.Text
  disclosureIa         Boolean       @default(false)
  disclosureTexto      String?       @db.Text
  dolphinProfileId     String?
  proxyRef             String?
  fingerprint          String?
  observacoes          String?       @db.Text
  dataCriacao          DateTime      @default(now())
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  contas          ContaPlataforma[]
  posts           Post[]
  credenciais     Credencial[]
  receitas        Receita[]
  custos          Custo[]
  imagens         ImagemGerada[]
  fluxosImagem    FluxoImagem[]
  statusHistorico PersonaStatusLog[]
}

enum PersonaStatus {
  ATIVA
  TESTE
  SHADOW_BAN
  SUSPENSA
  BANIDA
}

model PersonaStatusLog {
  id        String        @id @default(cuid())
  personaId String
  persona   Persona       @relation(fields: [personaId], references: [id], onDelete: Cascade)
  status    PersonaStatus
  motivo    String?
  data      DateTime      @default(now())
}

// ─── CONTAS DE PLATAFORMA ────────────────────────────────────────────────────

model ContaPlataforma {
  id               String      @id @default(cuid())
  personaId        String
  persona          Persona     @relation(fields: [personaId], references: [id], onDelete: Cascade)
  plataforma       Plataforma
  handle           String
  seguidoresAtual  Int         @default(0)
  metaSeguidores   Int?
  metaPrazo        DateTime?
  statusConta      StatusConta @default(ATIVA)
  engajamentoMedio Decimal?    @db.Decimal(5, 2)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  metricas MetricaHistorica[]
  posts    Post[]

  @@unique([personaId, plataforma])
}

enum Plataforma {
  INSTAGRAM
  TIKTOK
  YOUTUBE
  FANVUE
  FACEBOOK
}

enum StatusConta {
  ATIVA
  SHADOW_BAN
  BANIDA
  PAUSADA
}

model MetricaHistorica {
  id              String          @id @default(cuid())
  contaId         String
  conta           ContaPlataforma @relation(fields: [contaId], references: [id], onDelete: Cascade)
  data            DateTime
  seguidores      Int
  postsPublicados Int             @default(0)
  engajamento     Decimal?        @db.Decimal(5, 2)
  receitaDia      Decimal?        @default(0) @db.Decimal(10, 2)
  createdAt       DateTime        @default(now())

  @@index([contaId, data])
}

// ─── POSTS / ROTEIROS ────────────────────────────────────────────────────────

model Post {
  id               String           @id @default(cuid())
  personaId        String
  persona          Persona          @relation(fields: [personaId], references: [id], onDelete: Cascade)
  contaId          String?
  conta            ContaPlataforma? @relation(fields: [contaId], references: [id])
  tipo             TipoPost
  pilar            PilarConteudo
  titulo           String
  cenario          String?          @db.Text
  figurino         String?          @db.Text
  hook             String?          @db.Text
  roteiro          String?          @db.Text
  copyLegenda      String?          @db.Text
  promptIa         String?          @db.Text
  musicaSugerida   String?
  hashtags         String?          @db.Text
  recursos         String?          @db.Text
  edicao           String?          @db.Text
  posicaoElementos String?          @db.Text
  obsProducao      String?          @db.Text
  status           StatusPost       @default(PENDENTE)
  dataStatus       DateTime?
  dataPublicacao   DateTime?
  ordem            Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  imagens ImagemGerada[]

  @@index([personaId, status])
  @@index([dataPublicacao])
}

enum TipoPost {
  IMAGEM
  REEL
  STORY
  ENSAIO
  CARROSSEL
}

enum PilarConteudo {
  IDENTIDADE
  LIFESTYLE
  SENSUALIDADE
  BASTIDORES
}

enum StatusPost {
  PENDENTE
  APROVADO
  AGENDADO
  PUBLICADO
  REJEITADO
}

// ─── FUNIL DE MONETIZAÇÃO ────────────────────────────────────────────────────

model FunilMonetizacao {
  id             String   @id @default(cuid())
  personaId      String   @unique
  urlLandingPage String?
  statusDeploy   String   @default("planejada") // planejada, em_construcao, no_ar, offline
  linkAfiliado   String?
  plataformaAfil String? // braip, monetizze
  precoBaixo     Decimal? @db.Decimal(8, 2)
  precoAlto      Decimal? @db.Decimal(8, 2)
  observacoes    String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  checklistItems ChecklistItem[]
}

model ChecklistItem {
  id        String           @id @default(cuid())
  funilId   String
  funil     FunilMonetizacao @relation(fields: [funilId], references: [id], onDelete: Cascade)
  bloco     String // B1, B2, B3, etc.
  descricao String
  concluido Boolean          @default(false)
  dataConcl DateTime?
  ordem     Int              @default(0)
}

// ─── FINANCEIRO ──────────────────────────────────────────────────────────────

model Receita {
  id        String   @id @default(cuid())
  personaId String
  persona   Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  valor     Decimal  @db.Decimal(10, 2)
  canal     String // braip, fanvue, ppv, outro
  descricao String?
  data      DateTime
  createdAt DateTime @default(now())

  @@index([personaId, data])
}

model Custo {
  id         String   @id @default(cuid())
  personaId  String?
  persona    Persona? @relation(fields: [personaId], references: [id])
  valor      Decimal  @db.Decimal(10, 2)
  categoria  String // proxy, ferramenta, publicidade, outro
  ferramenta String? // magnific, iproyal, dolphin, elevenlabs
  descricao  String?
  data       DateTime
  global     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([data])
}

// ─── CREDENCIAIS ─────────────────────────────────────────────────────────────

model Credencial {
  id           String      @id @default(cuid())
  personaId    String?
  persona      Persona?    @relation(fields: [personaId], references: [id], onDelete: Cascade)
  ferramentaId String?
  ferramenta   Ferramenta? @relation(fields: [ferramentaId], references: [id], onDelete: SetNull)
  chave        String
  valorEnc     String      @db.Text // AES-256 encrypted
  categoria    String // instagram, tiktok, fanvue, braip, proxy, etc.
  global       Boolean     @default(false)
  servico      String? // nome do provedor (ex.: IPRoyal) — credenciais globais
  notas        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  logs CredencialLog[]

  @@index([ferramentaId])
}

// ─── GERAÇÃO DE IMAGENS ──────────────────────────────────────────────────────

model FluxoImagem {
  id           String      @id @default(cuid())
  personaId    String?
  persona      Persona?    @relation(fields: [personaId], references: [id], onDelete: Cascade)
  ferramentaId String?
  ferramentaRef Ferramenta? @relation(fields: [ferramentaId], references: [id], onDelete: SetNull)
  nome         String
  ferramenta   String // legado: nome textual; preferir ferramentaId
  objetivo     String
  confianca    Int         @default(3) // 1-5
  instrucoes   String      @db.Text
  ativo        Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([personaId])
}

model ImagemGerada {
  id         String   @id @default(cuid())
  personaId  String
  persona    Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  postId     String?
  post       Post?    @relation(fields: [postId], references: [id])
  fluxoId    String?
  ferramenta String
  prompt     String   @db.Text
  resultado  String? // URL ou caminho do arquivo
  status     String   @default("pendente") // pendente, aprovada, descartada
  notas      String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([personaId])
}

// ─── DISCOVERY ───────────────────────────────────────────────────────────────

model DiscoveryEntry {
  id        String          @id @default(cuid())
  tipo      TipoDiscovery
  titulo    String
  descricao String?         @db.Text
  status    StatusDiscovery @default(EM_ABERTO)
  tags      String[]
  personaId String?
  data      DateTime        @default(now())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([tipo, status])
}

enum TipoDiscovery {
  IDEIA
  EXPERIMENTO
  PROJETO
  TENDENCIA
  APRENDIZADO
}

enum StatusDiscovery {
  EM_ABERTO
  EM_ANDAMENTO
  CONCLUIDO
  DESCARTADO
}

// ─── PLANO SEMANAL ───────────────────────────────────────────────────────────

model PlanoSemanal {
  id          String   @id @default(cuid())
  personaId   String
  semana      String // ex: "2026-W25"
  objetivo    String?  @db.Text
  observacoes String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kpis KpiSemana[]

  @@unique([personaId, semana])
}

model KpiSemana {
  id          String       @id @default(cuid())
  planoId     String
  plano       PlanoSemanal @relation(fields: [planoId], references: [id], onDelete: Cascade)
  metrica     String
  valorInicio String?
  valorMeta   String?
  valorFinal  String?
}

// ─────────────────────────────────────────────────────────────────────────────
// CREATOR ENGINE (nível superior) — infraestrutura reutilizável entre personas
// ─────────────────────────────────────────────────────────────────────────────

// CE-01: Registro de Ferramentas
model Ferramenta {
  id                 String              @id @default(cuid())
  nome               String
  categoria          CategoriaFerramenta
  urlAcesso          String?
  versaoAtual        String?
  statusAssinatura   StatusAssinatura    @default(ATIVA)
  custoMensal        Decimal?            @db.Decimal(10, 2)
  dataRenovacao      DateTime?
  responsavelConta   String?
  documentacao       String?             @db.Text
  configuracaoPadrao Json?
  tags               String[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  fluxosImagem       FluxoImagem[]
  credenciais        Credencial[]
}

enum CategoriaFerramenta {
  GERACAO_IMAGEM
  ANTI_DETECCAO
  PROXY
  VOZ
  VIDEO
  PRODUTIVIDADE
  PLATAFORMA
}

enum StatusAssinatura {
  ATIVA
  PAUSADA
  TRIAL
  CANCELADA
}

// CE-04: Biblioteca de Prompts Globais (independente de persona)
model PromptGlobal {
  id             String          @id @default(cuid())
  titulo         String
  ferramenta     String? // nome da ferramenta usada (ex: magnific, nano banana)
  categoria      CategoriaPrompt
  prompt         String          @db.Text
  negativoPrompt String?         @db.Text
  parametros     Json?
  estiloBase     String?
  avaliacaoMedia Decimal?        @db.Decimal(3, 2)
  usos           Int             @default(0)
  tags           String[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  imagens PromptExemplo[]
}

enum CategoriaPrompt {
  PERSONAGEM
  CENARIO
  PRODUTO
  VIDEO
  UPSCALE
}

model PromptExemplo {
  id             String       @id @default(cuid())
  promptGlobalId String
  promptGlobal   PromptGlobal @relation(fields: [promptGlobalId], references: [id], onDelete: Cascade)
  url            String
  personaUsada   String? // slug da persona que usou o prompt
  createdAt      DateTime     @default(now())
}

// CE-02: Templates de Conteúdo (playbooks reutilizáveis com variáveis)
model TemplateConteudo {
  id         String            @id @default(cuid())
  titulo     String
  categoria  CategoriaTemplate
  nicho      String?
  plataforma Plataforma?
  pilar      PilarConteudo?
  conteudo   String            @db.Text
  tags       String[]
  usos       Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  variaveis VariavelTemplate[]
  exemplos  ExemploTemplate[]
}

enum CategoriaTemplate {
  ROTEIRO
  COPY
  HOOK
  ESTRATEGIA
  CALENDARIO
}

model VariavelTemplate {
  id          String           @id @default(cuid())
  templateId  String
  template    TemplateConteudo @relation(fields: [templateId], references: [id], onDelete: Cascade)
  nome        String // ex: nome_persona, nicho, cta
  descricao   String?
  valorPadrao String?
}

model ExemploTemplate {
  id            String           @id @default(cuid())
  templateId    String
  template      TemplateConteudo @relation(fields: [templateId], references: [id], onDelete: Cascade)
  personaUsada  String? // slug da persona
  conteudoFinal String           @db.Text
  createdAt     DateTime         @default(now())
}

// CE-03: SOPs (metodologias versionadas com execução guiada)
model Sop {
  id        String       @id @default(cuid())
  titulo    String
  categoria CategoriaSop
  versao    String       @default("1.0.0")
  status    StatusSop    @default(RASCUNHO)
  descricao String?      @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  passos    SopPasso[]
  historico SopHistorico[]
  execucoes ExecucaoSop[]
}

enum CategoriaSop {
  ONBOARDING
  ANTI_BAN
  ESCALADA
  PRODUCAO
  GERACAO_IMAGEM
  MONETIZACAO
}

enum StatusSop {
  RASCUNHO
  ATIVO
  DEPRECIADO
}

model SopPasso {
  id         String  @id @default(cuid())
  sopId      String
  sop        Sop     @relation(fields: [sopId], references: [id], onDelete: Cascade)
  ordem      Int
  titulo     String
  descricao  String? @db.Text
  ferramenta String? // ferramenta vinculada ao passo
}

model SopHistorico {
  id      String   @id @default(cuid())
  sopId   String
  sop     Sop      @relation(fields: [sopId], references: [id], onDelete: Cascade)
  versao  String
  mudanca String   @db.Text
  data    DateTime @default(now())
}

model ExecucaoSop {
  id               String    @id @default(cuid())
  sopId            String
  sop              Sop       @relation(fields: [sopId], references: [id], onDelete: Cascade)
  personaUsada     String? // slug da persona
  status           String    @default("em_andamento") // em_andamento, concluida
  passosConcluidos Json? // ids dos passos marcados
  iniciadaEm       DateTime  @default(now())
  concluidaEm      DateTime?
}

// ─────────────────────────────────────────────────────────────────────────────
// ESTÚDIO DE VÍDEO — esteira de estilização (Remotion + identidade Tactical Rebel)
// Vídeo bruto é produzido FORA da esteira e ingerido por diretório/upload; a
// esteira aplica branding/legenda por roteiro parametrizado e renderiza na VPS.
// personaId/postId são apenas referências (sem relação formal, como DiscoveryEntry)
// para não acoplar a esteira aos modelos existentes e preparar o gancho de
// publicação futura (n8n/Instagram) sem implementá-lo aqui.
// ─────────────────────────────────────────────────────────────────────────────

model FonteVideo {
  id           String   @id @default(cuid())
  personaId    String? // slug/id da persona (referência solta)
  arquivo      String   @unique // caminho relativo no volume de inbox
  nomeOriginal String
  duracaoSeg   Float    @default(0)
  largura      Int      @default(0)
  altura       Int      @default(0)
  fps          Float    @default(30)
  tamanhoBytes BigInt?
  origem       String   @default("scan") // scan | upload
  createdAt    DateTime @default(now())

  roteiros RoteiroEstilizacao[]
  jobs     JobRender[]

  @@index([personaId])
}

model AssetEstilizacao {
  id        String   @id @default(cuid())
  tag       String   @unique // referenciável pelo roteiro (ex.: moldura-tatica)
  nome      String
  tipo      String   @default("imagem") // imagem | overlay | lockup | cta
  arquivo   String
  descricao String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TemplateVideo {
  id         String         @id @default(cuid())
  slug       String         @unique
  nome       String
  descricao  String?        @db.Text
  composicao String // id da composição Remotion (ex.: gancho-incongruencia)
  formatos   FormatoVideo[]
  ativo      Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  roteiros RoteiroEstilizacao[]
  jobs     JobRender[]
}

model RoteiroEstilizacao {
  id              String         @id @default(cuid())
  personaId       String?
  nome            String
  formato         FormatoVideo   @default(VERTICAL_9_16)
  fonteVideoId    String?
  fonteVideo      FonteVideo?    @relation(fields: [fonteVideoId], references: [id], onDelete: SetNull)
  templateVideoId String?
  templateVideo   TemplateVideo? @relation(fields: [templateVideoId], references: [id], onDelete: SetNull)
  timeline        Json // { tracks: [...] } — validado por Zod (src/lib/estudio/timeline.ts)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  jobs JobRender[]

  @@index([personaId])
}

model JobRender {
  id              String             @id @default(cuid())
  roteiroId       String
  roteiro         RoteiroEstilizacao @relation(fields: [roteiroId], references: [id], onDelete: Cascade)
  fonteVideoId    String?
  fonteVideo      FonteVideo?        @relation(fields: [fonteVideoId], references: [id], onDelete: SetNull)
  templateVideoId String?
  templateVideo   TemplateVideo?     @relation(fields: [templateVideoId], references: [id], onDelete: SetNull)
  formato         FormatoVideo
  personaId       String?
  postId          String? // gancho de publicação futura
  status          StatusJobRender    @default(FILA)
  outputPath      String? // caminho relativo do MP4 final (registro estável de saída)
  metadados       Json?
  erro            String?            @db.Text
  tentativas      Int                @default(0)
  iniciadoEm      DateTime?
  concluidoEm     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([personaId])
}

enum FormatoVideo {
  VERTICAL_9_16
  QUADRADO_1_1
  RETRATO_4_5
}

enum StatusJobRender {
  FILA
  RENDERIZANDO
  POS
  PRONTO
  ERRO
}

// Trilha de auditoria de credenciais (RNF-01). credencialId vira null se a
// credencial for excluída (SetNull), mas o log permanece para auditoria.
model CredencialLog {
  id              String      @id @default(cuid())
  credencialId    String?
  credencial      Credencial? @relation(fields: [credencialId], references: [id], onDelete: SetNull)
  acao            String // CRIADA, REVELADA, EDITADA, EXCLUIDA
  credencialChave String // snapshot da chave para contexto pós-exclusão
  usuarioEmail    String
  data            DateTime    @default(now())

  @@index([data])
}
